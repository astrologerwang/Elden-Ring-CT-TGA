// Camera rotates around the player character when enabled

{$lua}
if syntaxcheck then return end

centerX = 12.6
centerY = 0
centerZ = 17
R = 15
H = 10
degree = 0
S = math.sqrt(R * R + H * H)

function getAddressP()
    local area = getAddressSafe("FieldArea")
    local p0 = readPointer(area)
    local p1 = readPointer(p0 + 0x20)
    local p2 = readPointer(p1 + 0xD0)
    return p2
end

P = getAddressP()

function rotateCamera()
    degree = (degree + 0.1) % 360
    local rad = math.rad(degree)

    local Fx = R * math.cos(rad) / S
    local Fy = H / S
    local Fz = R * math.sin(rad) / S

    local Lx = math.sin(rad)
    local Ly = 0
    local Lz = math.cos(rad)

    local _Ux = -Fx * Fy
    local _Uy = Fx * Fx + Fz * Fz
    local _Uz = -Fy * Fz

    local Ur = math.sqrt(_Ux * _Ux + _Uy * _Uy + _Uz * _Uz)
    local Ux = _Ux / Ur
    local Uy = _Uy / Ur
    local Uz = _Uz / Ur

    local newX = centerX + Fx * S
    local newZ = centerZ + Fz * S

    writeFloat(P + 0x10, Lx)
    writeFloat(P + 0x14, Ly)
    writeFloat(P + 0x18, Lz)

    writeFloat(P + 0x20, Ux)
    writeFloat(P + 0x24, Uy)
    writeFloat(P + 0x28, Uz)

    print(Ux, Uy, Uz)

    writeFloat(P + 0x30, -Fx)
    writeFloat(P + 0x34, -Fy)
    writeFloat(P + 0x38, -Fz)

    writeFloat(P + 0x40, newX)
    writeFloat(P + 0x44, H)
    writeFloat(P + 0x48, newZ)
end

