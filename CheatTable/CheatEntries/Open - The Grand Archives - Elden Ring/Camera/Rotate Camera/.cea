// Camera rotates around the player character when enabled

{$lua}
if syntaxcheck then return end

function rotateCamera()
    print("Rotating camera")
    local fieldArea = getAddressSafe("FieldArea")
    if fieldArea then
        local xAddress = readPointer(fieldArea)
        local x1 = readPointer(xAddress + 0x20)
        local x2 = readPointer(x1 + 0xD0)
        local xAddr = x2 + 0x40
        local x = readFloat(xAddr)
        print("X value: " .. x)
        -- local currentX = readFloat(xAddress) or 0
        writeFloat(xAddr, x + 1)
        -- print("X value: " .. currentX)
    end
end

[ENABLE]
rotationTimer = createTimer(getMainForm())
rotationTimer.Interval = 1000
rotationTimer.OnTimer = rotateCamera
rotationTimer.Enabled = true

[DISABLE]
if rotationTimer then
    print("Stopping camera rotation...")
    rotationTimer.Enabled = false
    rotationTimer.destroy()
    rotationTimer = nil
end