// Camera rotates around the player character when enabled

{$lua}
if syntaxcheck then return end

centerX = 12.6
centerY = 0
centerZ = -15
R = 10
H = 20
degree = 0

function getAddressP()
    local area = getAddressSafe("FieldArea")
    local p0 = readPointer(area)
    local p1 = readPointer(p0 + 0x20)
    local p2 = readPointer(p1 + 0xD0)
    return p2
end

P = getAddressP()

function getAddressX()
    return P + 0x40
end

function getAddressY()
    return P + 0x44
end

function getAddressZ()
    return P + 0x48
end

function rotateCamera()
    local xAddr = getAddressX()
    local zAddr = getAddressZ()

    degree = (degree + 0.5) % 360
    local rad = math.rad(degree)

    local newX = centerX + R * math.cos(rad)
    local newZ = centerZ + R * math.sin(rad)

    writeFloat(xAddr, newX)
    writeFloat(zAddr, newZ)
end

[ENABLE]
writeFloat(yAddr, H)
rotationTimer = createTimer(getMainForm())
rotationTimer.Interval = 10
rotationTimer.OnTimer = rotateCamera
rotationTimer.Enabled = true

[DISABLE]
if rotationTimer then
    rotationTimer.Enabled = false
    rotationTimer.destroy()
    rotationTimer = nil
end